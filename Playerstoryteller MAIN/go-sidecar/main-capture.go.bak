// Configuration
const (
	ServerURL       = "ws://localhost:3000/webrtc-signal"
	FFmpegPath      = "ffmpeg.exe"
	LogFileName     = "sidecar-capture.log"
	FrameBufferSize = 3 // Buffer for captured frames
	FeedbackPort    = 9000
	TargetFPS       = 30
	CaptureQuality  = 75 // JPEG quality
)

var (
	logger          *log.Logger
	sessionID       string
	streamKey       string
	rimworldPID     uint32
	peerConn        *webrtc.PeerConnection
	dataChannel     *webrtc.DataChannel
	wsConn          *websocket.Conn
	wsMutex         sync.Mutex
	ffmpegCmd       *exec.Cmd
	ffmpegStdin     io.WriteCloser
	mu              sync.Mutex
	fpsTracker      *FPSTracker
	hardwareEncoder string
	windowCapture   *WindowCapture
	captureStopChan chan struct{}
)

func main() {
	// Setup Logging
	setupLogging()
	logMsg("Sidecar started (Window Capture Mode)")

	// Detect hardware encoder
	hardwareEncoder = detectHardwareEncoder()
	if hardwareEncoder != "" {
		logMsg(fmt.Sprintf("Hardware encoder detected: %s", hardwareEncoder))
	} else {
		logMsg("No hardware encoder detected. Using CPU encoding (libx264).")
	}

	// Initialize FPS Tracker
	fpsTracker = NewFPSTracker(TargetFPS, 30)

	var providedSessionID string
	var providedPIDStr string

	// Parse arguments
	for i := 1; i < len(os.Args); i++ {
		arg := os.Args[i]
		if arg == "--rimworld-pid" && i+1 < len(os.Args) {
			providedPIDStr = os.Args[i+1]
			i++
		} else if arg == "--stream-key" && i+1 < len(os.Args) {
			streamKey = os.Args[i+1]
			i++
		} else if !strings.HasPrefix(arg, "--") && providedSessionID == "" {
			providedSessionID = arg
		}
	}

	if providedSessionID != "" {
		sessionID = providedSessionID
	} else {
		sessionID = "current-session"
	}

	if providedPIDStr != "" {
		pid64, err := strconv.ParseUint(providedPIDStr, 10, 32)
		if err != nil {
			logMsg(fmt.Sprintf("Invalid RimWorld PID: %s, error: %v", providedPIDStr, err))
			os.Exit(1)
		}
		rimworldPID = uint32(pid64)
	} else {
		logMsg("ERROR: --rimworld-pid is required")
		os.Exit(1)
	}

	if streamKey == "" {
		logMsg("WARNING: No stream key provided! Authentication may fail.")
	}

	logMsg(fmt.Sprintf("Session ID: %s", sessionID))
	logMsg(fmt.Sprintf("Capturing RimWorld PID: %d", rimworldPID))

	// Monitor parent process
	go monitorParentProcess(rimworldPID)

	// Start HTTP Feedback Server
	go startFeedbackServer()

	// Initialize window capture
	windowCapture = NewWindowCapture(rimworldPID)
	captureStopChan = make(chan struct{})

	// Connect to Signaling Server
	connectSignaling()

	// Keep main thread alive
	select {}
}

func startCapture() {
	mu.Lock()
	defer mu.Unlock()

	if windowCapture == nil {
		logMsg("ERROR: Window capture not initialized")
		return
	}

	// Start capture loop in goroutine
	frameChan := make(chan []byte, FrameBufferSize)

	go windowCapture.CaptureLoop(TargetFPS, CaptureQuality, frameChan, captureStopChan)

	// Start frame consumer (feeds to FFmpeg)
	go func() {
		for frame := range frameChan {
			mu.Lock()
			stdin := ffmpegStdin
			mu.Unlock()

			if stdin != nil {
				fpsTracker.RecordFrame()
				_, err := stdin.Write(frame)
				if err != nil {
					logMsg(fmt.Sprintf("Failed to write frame to FFmpeg: %v", err))
				}
			}
		}
	}()

	logMsg("Window capture started")
}

func stopCapture() {
	close(captureStopChan)
	captureStopChan = make(chan struct{}) // Reset for next use
	logMsg("Window capture stopped")
}

