// Modified monitorParentProcess to accept PID
func monitorParentProcess(parentPID uint32) {
	if parentPID == 0 {
		logMsg("Parent PID is 0, not monitoring parent process.")
		return
	}

	ticker := time.NewTicker(5 * time.Second)
	defer ticker.Stop()

	logMsg(fmt.Sprintf("Started monitoring parent process with PID %d", parentPID))

	for range ticker.C {
		handle, err := windows.OpenProcess(windows.PROCESS_QUERY_INFORMATION, false, parentPID)
		if err != nil {
			logMsg(fmt.Sprintf("Failed to open handle to parent process (PID %d): %v. Terminating sidecar.", parentPID, err))
			os.Exit(1)
			return
		}
		defer windows.CloseHandle(handle)

		var exitCode uint32
		err = windows.GetExitCodeProcess(handle, &exitCode)
		if err != nil {
			logMsg(fmt.Sprintf("Failed to get exit code for parent process (PID %d): %v. Terminating sidecar.", parentPID, err))
			os.Exit(1)
			return
		}

		if exitCode != STILL_ACTIVE {
			logMsg(fmt.Sprintf("Parent process (PID %d) has exited with code %d. Terminating sidecar.", parentPID, exitCode))
			os.Exit(1)
			return
		}
	}
}

// Modified handleOffer to start capture when data channel opens
func handleOfferModified(msg SignalMessage) {
	config := webrtc.Configuration{
		ICEServers: []webrtc.ICEServer{
			{URLs: []string{"stun:stun.l.google.com:19302"}},
		},
	}

	var err error
	peerConn, err = webrtc.NewPeerConnection(config)
	if err != nil {
		logMsg(fmt.Sprintf("Failed to create PeerConn: %v", err))
		return
	}

	peerConn.OnICECandidate(func(c *webrtc.ICECandidate) {
		if c == nil {
			return
		}
		candidate := c.ToJSON()
		sendSignal(SignalMessage{
			Type:      "ice-candidate",
			Candidate: &candidate,
			To:        msg.From,
			SessionID: sessionID,
		})
	})

	peerConn.OnConnectionStateChange(func(s webrtc.PeerConnectionState) {
		logMsg(fmt.Sprintf("Peer Connection State: %s", s.String()))
	})

	peerConn.OnDataChannel(func(d *webrtc.DataChannel) {
		logMsg(fmt.Sprintf("New DataChannel: %s %d", d.Label(), d.ID()))
		dataChannel = d

		d.OnOpen(func() {
			logMsg("DataChannel Open. Starting window capture...")
			time.Sleep(1000 * time.Millisecond)
			startFFmpeg()
			startCapture()
		})

		d.OnClose(func() {
			logMsg("DataChannel Closed. Stopping capture...")
			stopCapture()
			stopFFmpeg()
		})
	})

	if err := peerConn.SetRemoteDescription(*msg.Offer); err != nil {
		logMsg(fmt.Sprintf("SetRemoteDesc error: %v", err))
		return
	}

	answer, err := peerConn.CreateAnswer(nil)
	if err != nil {
		logMsg(fmt.Sprintf("CreateAnswer error: %v", err))
		return
	}

	if err := peerConn.SetLocalDescription(answer); err != nil {
		logMsg(fmt.Sprintf("SetLocalDesc error: %v", err))
		return
	}

	sendSignal(SignalMessage{
		Type:      "answer",
		Answer:    &answer,
		To:        msg.From,
		SessionID: sessionID,
	})
}

